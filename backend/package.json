{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "PawMate backend scaffold",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --runInBand --config jest.config.cjs",
    "test:coverage": "jest --runInBand --config jest.config.cjs --coverage",
    "smoke:runtime": "tsx ./scripts/day2-runtime-smoke.ts",
    "auth:live-proof": "tsx ./scripts/day2-auth-live-proof.ts",
    "seed:vets:build": "node ./scripts/build-day2-vet-seed-candidates.mjs",
    "seed:vets:validate-geo-pilot": "node ./scripts/validate-day3-vet-geo-pilot.mjs",
    "seed:vets:sync-geo-pilot": "node ./scripts/sync-day3-vet-geo-pilot.mjs",
    "seed:vets:perf": "node ./scripts/seed-day3-vet-benchmark.mjs",
    "benchmark:vets:nearby": "node ./scripts/benchmark-day3-vet-nearby.mjs",
    "test:vets:nearby-matrix": "tsx ./scripts/day3-vet-nearby-matrix.ts",
    "db:day5:unblock": "node ./scripts/day5-db-unblock.cjs",
    "db:day6:cloud-proof": "node ./scripts/day6-cloud-schema-proof.cjs",
    "reminders:process-due": "tsx ./src/jobs/process-due-reminders.ts",
    "prisma:validate": "node ./scripts/prisma-validate.cjs",
    "supabase:bootstrap": "node ./scripts/supabase-bootstrap.cjs"
  },
  "keywords": [
    "fastify",
    "typescript",
    "pawmate"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@supabase/supabase-js": "^2.102.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
